# Note: Next.js 16 requires Node.js 20.9 or later

# Gemini API (free) - https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_key_here

# Clerk Auth - https://clerk.com (free tier)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_key_here
CLERK_SECRET_KEY=sk_test_your_key_here
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# Stripe - https://stripe.com
STRIPE_SECRET_KEY=sk_test_your_key_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
STRIPE_PRICE_ID=price_your_price_id_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase - https://supabase.com (free tier)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Amazon Associates (optional)
NEXT_PUBLIC_AMAZON_AFFILIATE_TAG=yourtag-20

# Dev bypass — comma-separated emails that skip the Stripe paywall
# Remove or leave blank in production
NEXT_PUBLIC_DEV_EMAILS=your@email.com
